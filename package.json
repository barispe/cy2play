{
  "name": "cy2play",
  "version": "0.1.0",
  "description": "A CLI tool that uses LLMs to transpile Cypress/WebdriverIO tests into Playwright.",
  "main": "dist/index.js",
  "bin": {
    "cy2play": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "ts-node src/cli.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "testing",
    "playwright",
    "cypress",
    "migration",
    "ai",
    "llm"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "langchain": "^0.0.207",
    "openai": "^4.20.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}
