# Cy2Play Environment Variables
# Copy this file to .env and fill in the values you need.

# OpenAI API Key (required for --provider openai)
# OPENAI_API_KEY=sk-...

# Anthropic API Key (required for --provider anthropic)
# ANTHROPIC_API_KEY=sk-ant-...

# Local LLM Base URL (for Ollama / LM Studio)
# LOCAL_LLM_URL=http://localhost:11434/v1

# Local LLM Model Name
# LOCAL_LLM_MODEL=codellama
